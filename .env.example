# =============================================================================
# KnowledgeHive Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- LLM Provider (OpenRouter) ---
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.0-flash-001
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Embedding Model ---
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Qdrant Vector Database ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=knowledge_hive

# --- Neo4j Graph Database ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=knowledgehive

# --- Application Settings ---
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# --- Authentication (Phase 2) ---
# Leave empty to disable auth (local dev mode)
API_KEY=

# --- Rate Limiting (Phase 2) ---
RATE_LIMIT_UPLOAD=10/minute
RATE_LIMIT_QUERY=30/minute
RATE_LIMIT_HEALTH=60/minute

# --- Debug Mode ---
# Set to true for human-readable logs; false for JSON structured logs
DEBUG=true

# --- Backend Server ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# --- Frontend ---
VITE_API_URL=http://localhost:8000

# --- Redis (Phase 3) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- Cache TTL (seconds) ---
CACHE_TTL_QUERY=3600
CACHE_TTL_LLM=3600
CACHE_TTL_ENTITIES=86400

# --- Celery (Phase 3) ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_WORKER_CONCURRENCY=2

# --- Langfuse (Phase 4 - not used yet) ---
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
